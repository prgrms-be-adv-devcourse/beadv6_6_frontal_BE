##############################################################################
#  Biddy Auction Service - HTTP API Test
#  Base URL: http://localhost:8084
#
#  사용법: IntelliJ에서 각 요청 옆 ▶ 버튼 클릭 또는 Ctrl+Enter
#  전제조건: Seed Data가 입력된 상태 (02-auction-seed-data.sql)
##############################################################################


### ========== 1. 경매 피드 조회 (GET /api/v1/auctions) ==========
# 경매 목록을 필터/정렬/페이징하여 조회한다.
# status: LIVE | ENDED, sort: ending | price | latest, category: 문자열

### 1-1. 전체 경매 피드 조회
# 파라미터 없이 호출 시 기본값: page=0, size=20, sort=latest(최신순)
GET http://localhost:8084/api/v1/auctions
Accept: application/json

### 1-2. LIVE 경매만 조회
# 현재 진행 중인 경매만 필터링
GET http://localhost:8084/api/v1/auctions?status=LIVE
Accept: application/json

### 1-3. ENDED 경매만 조회
# 종료된 경매만 필터링 (낙찰/유찰 포함)
GET http://localhost:8084/api/v1/auctions?status=ENDED
Accept: application/json

### 1-4. 카테고리 필터
# 특정 카테고리의 경매만 조회
GET http://localhost:8084/api/v1/auctions?category=sneakers
Accept: application/json

### 1-5. 마감임박순 정렬
# endsAt ASC — 종료 시간이 가까운 경매가 먼저
GET http://localhost:8084/api/v1/auctions?sort=ending
Accept: application/json

### 1-6. 높은 가격순 정렬
# currentBid DESC — 현재 입찰가가 높은 경매가 먼저
GET http://localhost:8084/api/v1/auctions?sort=price
Accept: application/json

### 1-7. 최신순 정렬 (기본값)
# createdAt DESC — 최근 등록된 경매가 먼저
GET http://localhost:8084/api/v1/auctions?sort=latest
Accept: application/json

### 1-8. 복합 필터 (LIVE + 카테고리 + 마감임박순 + 페이지네이션)
# 여러 조건을 동시에 적용
GET http://localhost:8084/api/v1/auctions?status=LIVE&category=sneakers&sort=ending&page=0&size=10
Accept: application/json

### 1-9. 2페이지 조회
# page=1 (0-based), size=5 — 6~10번째 경매
GET http://localhost:8084/api/v1/auctions?page=1&size=5
Accept: application/json


### ========== 2. 경매 상세 조회 (GET /api/v1/auctions/{auctionId}) ==========
# 특정 경매의 상세 정보를 조회한다.
# 응답: 상품정보 + 가격 + 통계 + topBidder

### 2-1. 경매 상세 조회 (정상)
# 경매 ID로 상세 정보 조회 — topBidder, watcherCount 포함
GET http://localhost:8084/api/v1/auctions/A-AJ1HI
Accept: application/json

### 2-2. 존재하지 않는 경매 (404 AUCTION_NOT_FOUND)
# 없는 경매 ID → ErrorResponse 반환
GET http://localhost:8084/api/v1/auctions/A-NOTEXIST
Accept: application/json


### ========== 3. 입찰 (POST /api/v1/auctions/{auctionId}/bids) ==========
# 경매에 입찰한다.
# 요청: { bidderId, amount }
# 검증: 경매 존재 → LIVE 상태 → 본인 경매 아님 → 금액 >= currentBid + minIncrement
# 비관적 락(SELECT FOR UPDATE)으로 동시 입찰 직렬화

### 3-1. 입찰 실행 (정상)
# amount가 currentBid + minIncrement 이상이면 성공
# 응답: bidId, amount, currentBid(갱신됨), bidCount(+1)
POST http://localhost:8084/api/v1/auctions/A-AJ1HI/bids
Content-Type: application/json

{
  "bidderId": 42,
  "amount": 1600000
}

### 3-2. 최소 입찰 단위 미달 (400 BID_AMOUNT_TOO_LOW)
# amount < currentBid + minIncrement → 입찰 거부
# minIncrement=20000일 때 currentBid+20000 이상이어야 함
POST http://localhost:8084/api/v1/auctions/A-AJ1HI/bids
Content-Type: application/json

{
  "bidderId": 43,
  "amount": 100
}

### 3-3. 본인 경매 입찰 (403 SELF_BID_NOT_ALLOWED)
# bidderId가 경매의 sellerId와 동일하면 입찰 불가
# Seed Data에서 A-AJ1HI의 sellerId=10
POST http://localhost:8084/api/v1/auctions/A-AJ1HI/bids
Content-Type: application/json

{
  "bidderId": 10,
  "amount": 2000000
}

### 3-4. 종료된 경매 입찰 (409 AUCTION_ALREADY_ENDED)
# status=ENDED인 경매에는 입찰 불가
POST http://localhost:8084/api/v1/auctions/A-ENDED1/bids
Content-Type: application/json

{
  "bidderId": 42,
  "amount": 500000
}

### 3-5. 존재하지 않는 경매에 입찰 (404 AUCTION_NOT_FOUND)
POST http://localhost:8084/api/v1/auctions/A-NOTEXIST/bids
Content-Type: application/json

{
  "bidderId": 42,
  "amount": 500000
}

### 3-6. 연속 입찰 테스트 (다른 입찰자가 더 높은 금액 입찰)
# 3-1 실행 후 다른 bidderId로 더 높은 금액 입찰
POST http://localhost:8084/api/v1/auctions/A-AJ1HI/bids
Content-Type: application/json

{
  "bidderId": 55,
  "amount": 1650000
}


### ========== 4. 입찰 내역 조회 (GET /api/v1/auctions/{auctionId}/bids) ==========
# 특정 경매의 전체 입찰 내역을 최신순(bidAt DESC)으로 페이징 조회한다.
# 응답: bidder(collectorId, nickname), amount, bidAt

### 4-1. 입찰 내역 조회 (기본값)
# 최신 입찰이 먼저 표시됨
GET http://localhost:8084/api/v1/auctions/A-AJ1HI/bids
Accept: application/json

### 4-2. 입찰 내역 페이지네이션
GET http://localhost:8084/api/v1/auctions/A-AJ1HI/bids?page=0&size=10
Accept: application/json

### 4-3. 입찰 내역 2페이지
GET http://localhost:8084/api/v1/auctions/A-AJ1HI/bids?page=1&size=5
Accept: application/json

### 4-4. 입찰 없는 경매의 내역 (빈 결과)
# 존재하지 않는 경매 또는 입찰이 없는 경매 → content: []
GET http://localhost:8084/api/v1/auctions/A-NOTEXIST/bids
Accept: application/json


### ========== 5. 관심 경매 등록/해제 (POST /api/v1/auctions/{auctionId}/watch) ==========
# 토글 방식: 첫 호출 → 등록(watching:true), 재호출 → 해제(watching:false)
# watcherCount도 함께 증감됨
# 같은 요청을 연속 2번 실행하여 토글 동작 확인 가능

### 5-1. 관심 경매 등록 (1회차 → watching: true)
# 처음 호출 시 관심 등록, watcherCount +1
POST http://localhost:8084/api/v1/auctions/A-AJ1HI/watch?memberId=42
Accept: application/json

### 5-2. 관심 경매 해제 (2회차 → watching: false)
# 같은 요청 재호출 시 관심 해제, watcherCount -1
POST http://localhost:8084/api/v1/auctions/A-AJ1HI/watch?memberId=42
Accept: application/json

### 5-3. 다른 경매 관심 등록
POST http://localhost:8084/api/v1/auctions/A-BK2FJ/watch?memberId=42
Accept: application/json

### 5-4. 존재하지 않는 경매 관심 등록 (404)
POST http://localhost:8084/api/v1/auctions/A-NOTEXIST/watch?memberId=42
Accept: application/json


### ========== 6. 내 관심 경매 목록 (GET /api/v1/members/me/watches) ==========
# 내가 관심 등록한 경매 목록을 조회한다.
# 응답: auctionId, name, thumbnailUrl, status, currentBid, endsAt

### 6-1. 내 관심 경매 목록 조회
# memberId로 관심 등록한 경매를 최신순으로 조회
GET http://localhost:8084/api/v1/members/me/watches?memberId=42
Accept: application/json

### 6-2. 내 관심 경매 목록 페이지네이션
GET http://localhost:8084/api/v1/members/me/watches?memberId=42&page=0&size=5
Accept: application/json

### 6-3. 관심 경매가 없는 회원 (빈 결과)
GET http://localhost:8084/api/v1/members/me/watches?memberId=9999
Accept: application/json


### ========== 7. 낙찰 결과 조회 (GET /api/v1/auctions/{auctionId}/result) ==========
# 종료된 경매의 낙찰/유찰 결과를 조회한다.
# LIVE 상태 → 409 AUCTION_STILL_LIVE
# ENDED + 입찰 있음 → SOLD (winnerId, finalBid, paymentDeadline)
# ENDED + 입찰 없음 → UNSOLD (winner: null)

### 7-1. 낙찰 결과 조회 (SOLD)
# 입찰이 있는 종료 경매 → 최고 입찰자가 낙찰자
GET http://localhost:8084/api/v1/auctions/A-ENDED1/result
Accept: application/json

### 7-2. 유찰 결과 조회 (UNSOLD)
# 입찰 없이 종료된 경매 → 미판매 처리
GET http://localhost:8084/api/v1/auctions/A-ENDED2/result
Accept: application/json

### 7-3. 진행 중 경매 결과 조회 (409 AUCTION_STILL_LIVE)
# LIVE 상태에서는 결과를 조회할 수 없음
GET http://localhost:8084/api/v1/auctions/A-AJ1HI/result
Accept: application/json

### 7-4. 존재하지 않는 경매 결과 조회 (404 AUCTION_NOT_FOUND)
GET http://localhost:8084/api/v1/auctions/A-NOTEXIST/result
Accept: application/json


### ========== 8. 내 입찰 참여 목록 (GET /api/v1/members/me/bids) ==========
# 내가 입찰에 참여한 경매 목록을 조회한다.
# 각 경매에 대해 myHighestBid(내 최고 입찰액), isTopBidder(최고입찰자 여부) 포함
# status 필터로 LIVE/ENDED 분리 가능

### 8-1. 내 입찰 참여 목록 전체
# 내가 입찰한 모든 경매 (LIVE + ENDED)
GET http://localhost:8084/api/v1/members/me/bids?bidderId=42
Accept: application/json

### 8-2. LIVE 경매만 필터
# 현재 진행 중인 경매 중 내가 입찰한 것만
GET http://localhost:8084/api/v1/members/me/bids?bidderId=42&status=LIVE
Accept: application/json

### 8-3. ENDED 경매만 필터
# 종료된 경매 중 내가 입찰한 것만 (낙찰 여부 확인용)
GET http://localhost:8084/api/v1/members/me/bids?bidderId=42&status=ENDED
Accept: application/json

### 8-4. 페이지네이션
GET http://localhost:8084/api/v1/members/me/bids?bidderId=42&page=0&size=5
Accept: application/json

### 8-5. 입찰 이력 없는 회원 (빈 결과)
GET http://localhost:8084/api/v1/members/me/bids?bidderId=9999
Accept: application/json


##############################################################################
#  WebSocket 테스트
#  WebSocket은 HTTP 테스트로 직접 호출 불가.
#  아래 방법으로 테스트:
#
#  1. 브라우저: http://localhost:8084 접속 → 테스트 콘솔
#  2. STOMP 구독 경로: /topic/auctions/{auctionId}
#  3. 메시지 타입:
#     - BID:    { type: "BID", currentBid, bidCount, bidderId }
#     - ENDED:  { type: "ENDED", auctionId, winnerId, finalBid }
#     - UNSOLD: { type: "UNSOLD", auctionId }
##############################################################################
